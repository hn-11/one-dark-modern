{
  "name": "one-dark-modern",
  "displayName": "One Dark Modern",
  "description": "A color theme inspired by Atom One Dark and Dark Modern",
  "version": "0.0.28",
  "publisher": "hn-11",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hn-11/one-dark-modern.git"
  },
  "scripts": {
    "build": "node scripts/build.ts && node scripts/build-zed.ts && node scripts/build-jetbrains.ts && node scripts/build-ghostty.ts && node scripts/build-windows-terminal.ts && node scripts/build-vim.ts",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "vscode:prepublish": "npm run build",
    "audit": "node scripts/audit-flicker.ts",
    "version": "npm run build && git add themes",
    "postversion": "git push origin main --tags"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.8.0",
    "typescript-language-server": "^5.3.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=23.6.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "One Dark Modern",
        "uiTheme": "vs-dark",
        "path": "./themes/one-dark-modern-color-theme.json"
      },
      {
        "label": "One Dark 2026",
        "uiTheme": "vs-dark",
        "path": "./themes/one-dark-2026-color-theme.json"
      },
      {
        "label": "Zed One Dark Modern",
        "uiTheme": "vs-dark",
        "path": "./themes/zed-one-dark-modern-color-theme.json"
      },
      {
        "label": "Zed One Dark 2026",
        "uiTheme": "vs-dark",
        "path": "./themes/zed-one-dark-2026-color-theme.json"
      }
    ]
  }
}
