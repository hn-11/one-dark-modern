{
  "name": "one-dark-modern",
  "displayName": "One Dark Modern",
  "description": "A color theme inspired by Atom One Dark and Dark Modern",
  "version": "0.0.10",
  "publisher": "hn-11",
  "repository": {
    "type": "git",
    "url": "https://github.com/hn-11/one-dark-modern.git"
  },
  "scripts": {
    "merge": "cd .. && node one-dark-modern/theme-builder.js merge one-dark-modern",
    "bump": "cd .. && node one-dark-modern/theme-builder.js bump one-dark-modern",
    "package": "npx --yes @vscode/vsce package"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "One Dark Modern",
        "uiTheme": "vs-dark",
        "path": "./themes/one-dark-modern-color-theme.json"
      }
    ]
  }
}