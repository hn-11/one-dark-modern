  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5d636f"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#878e98"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "meta.preprocessor keyword",
        "keyword.operator.word",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#b477cf"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#878e98"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": "constant.language.boolean",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": [
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#dfc184"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#dfc184"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#73ade9"
      }
    },
    {
      "scope": "storage.type.function.arrow",
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": [
        "keyword.operator.type",
        "keyword.operator.optional"
      ],
      "settings": {
        "foreground": "#b1574b"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": [
        "entity.name.namespace",
        "entity.name.package",
        "entity.name.type.package"
      ],
      "settings": {
        "foreground": "#dce0e5"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": "variable.other.enummember",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#acb2be"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.terminator",
        "punctuation.other"
      ],
      "settings": {
        "foreground": "#b2b9c6"
      }
    },
    {
      "scope": [
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.typeparameters",
        "punctuation.definition.arguments",
        "punctuation.definition.array",
        "punctuation.section",
        "punctuation.definition.begin",
        "punctuation.definition.end",
        "punctuation.definition.bracket",
        "punctuation.definition.binding-pattern",
        "punctuation.definition.imports"
      ],
      "settings": {
        "foreground": "#b2b9c6"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#74ade8"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#74ade8"
      }
    },
    {
      "scope": "entity.name.label",
      "settings": {
        "foreground": "#74ade8"
      }
    },
    {
      "scope": [
        "punctuation.section.embedded",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#b1574b"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#74ade8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "invalid.illegal",
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "scope": [
        "entity.name.command.shell",
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": "constant.other.option",
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": "string.unquoted.argument",
      "settings": {
        "foreground": "#acb2be"
      }
    }
