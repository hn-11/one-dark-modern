{
  "$schema": "vscode://schemas/color-theme",
  "name": "Zed One Dark Modern",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "activityBar.activeBorder": "#74ade8",
    "activityBar.background": "#181818",
    "activityBar.border": "#2B2B2B",
    "activityBar.foreground": "#D7D7D7",
    "activityBar.inactiveForeground": "#868686",
    "activityBarBadge.background": "#74ade8",
    "activityBarBadge.foreground": "#FFFFFF",
    "badge.background": "#616161",
    "badge.foreground": "#F8F8F8",
    "button.background": "#74ade8",
    "button.border": "#ffffff1a",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#026EC1",
    "button.secondaryBackground": "#00000000",
    "button.secondaryForeground": "#CCCCCC",
    "button.secondaryHoverBackground": "#2B2B2B",
    "chat.editedFileForeground": "#E2C08D",
    "chat.slashCommandBackground": "#26477866",
    "chat.slashCommandForeground": "#85B6FF",
    "checkbox.background": "#313131",
    "checkbox.border": "#3C3C3C",
    "debugToolBar.background": "#181818",
    "descriptionForeground": "#9D9D9D",
    "dropdown.background": "#313131",
    "dropdown.border": "#3C3C3C",
    "dropdown.foreground": "#CCCCCC",
    "dropdown.listBackground": "#1F1F1F",
    "editor.background": "#1F1F1F",
    "editor.findMatchBackground": "#9E6A03",
    "editor.foreground": "#acb2be",
    "editor.selectionBackground": "#74ade83d",
    "editorCursor.foreground": "#74ade8",
    "editorGroup.border": "#FFFFFF17",
    "editorGroupHeader.tabsBackground": "#181818",
    "editorGroupHeader.tabsBorder": "#2B2B2B",
    "editorGutter.addedBackground": "#2EA043",
    "editorGutter.deletedBackground": "#F85149",
    "editorGutter.modifiedBackground": "#74ade8",
    "editorLineNumber.activeForeground": "#CCCCCC",
    "editorLineNumber.foreground": "#6E7681",
    "editorOverviewRuler.border": "#010409",
    "editorSuggestWidget.selectedBackground": "#454a56",
    "editorWidget.background": "#202020",
    "errorForeground": "#F85149",
    "focusBorder": "#74ade8",
    "foreground": "#CCCCCC",
    "icon.foreground": "#CCCCCC",
    "input.background": "#313131",
    "input.border": "#3C3C3C",
    "input.foreground": "#CCCCCC",
    "input.placeholderForeground": "#989898",
    "inputOption.activeBackground": "#74ade83d",
    "inputOption.activeBorder": "#47679e",
    "keybindingLabel.foreground": "#CCCCCC",
    "list.activeSelectionBackground": "#454a56",
    "list.focusOutline": "#47679e",
    "list.hoverBackground": "#363c46",
    "list.inactiveSelectionBackground": "#363c46",
    "menu.background": "#1F1F1F",
    "menu.selectionBackground": "#454a56",
    "menu.selectionForeground": "#dce0e5",
    "notificationCenterHeader.background": "#1F1F1F",
    "notificationCenterHeader.foreground": "#CCCCCC",
    "notifications.background": "#1F1F1F",
    "notifications.border": "#2B2B2B",
    "notifications.foreground": "#CCCCCC",
    "panel.background": "#181818",
    "panel.border": "#2B2B2B",
    "panelInput.border": "#2B2B2B",
    "panelTitle.activeBorder": "#74ade8",
    "panelTitle.activeForeground": "#CCCCCC",
    "panelTitle.inactiveForeground": "#9D9D9D",
    "peekViewEditor.background": "#1F1F1F",
    "peekViewEditor.matchHighlightBackground": "#BB800966",
    "peekViewResult.background": "#1F1F1F",
    "peekViewResult.matchHighlightBackground": "#BB800966",
    "pickerGroup.border": "#3C3C3C",
    "progressBar.background": "#74ade8",
    "quickInput.background": "#222222",
    "quickInput.foreground": "#CCCCCC",
    "quickInputList.focusBackground": "#454a56",
    "settings.dropdownBackground": "#313131",
    "settings.dropdownBorder": "#3C3C3C",
    "settings.headerForeground": "#FFFFFF",
    "settings.modifiedItemIndicator": "#BB800966",
    "sideBar.background": "#181818",
    "sideBar.border": "#2B2B2B",
    "sideBar.foreground": "#CCCCCC",
    "sideBarSectionHeader.background": "#181818",
    "sideBarSectionHeader.border": "#2B2B2B",
    "sideBarSectionHeader.foreground": "#CCCCCC",
    "sideBarTitle.foreground": "#CCCCCC",
    "statusBar.background": "#181818",
    "statusBar.border": "#2B2B2B",
    "statusBar.debuggingBackground": "#74ade8",
    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBar.focusBorder": "#74ade8",
    "statusBar.foreground": "#CCCCCC",
    "statusBar.noFolderBackground": "#1F1F1F",
    "statusBarItem.focusBorder": "#74ade8",
    "statusBarItem.hoverBackground": "#F1F1F133",
    "statusBarItem.hoverForeground": "#FFFFFF",
    "statusBarItem.prominentBackground": "#6E768166",
    "statusBarItem.remoteBackground": "#74ade8",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "tab.activeBackground": "#1F1F1F",
    "tab.activeBorder": "#1F1F1F",
    "tab.activeBorderTop": "#74ade8",
    "tab.activeForeground": "#FFFFFF",
    "tab.border": "#2B2B2B",
    "tab.hoverBackground": "#1F1F1F",
    "tab.inactiveBackground": "#181818",
    "tab.inactiveForeground": "#9D9D9D",
    "tab.selectedBorderTop": "#6caddf",
    "tab.unfocusedActiveBorder": "#1F1F1F",
    "tab.unfocusedActiveBorderTop": "#2B2B2B",
    "tab.unfocusedHoverBackground": "#1F1F1F",
    "terminal.ansiBlack": "#282c34",
    "terminal.ansiBlue": "#61afef",
    "terminal.ansiBrightBlack": "#636d83",
    "terminal.ansiBrightBlue": "#85C1FF",
    "terminal.ansiBrightCyan": "#6ED5DE",
    "terminal.ansiBrightGreen": "#AAD581",
    "terminal.ansiBrightMagenta": "#D398EB",
    "terminal.ansiBrightRed": "#EA858B",
    "terminal.ansiBrightWhite": "#fafafa",
    "terminal.ansiBrightYellow": "#FFD885",
    "terminal.ansiCyan": "#56b6c2",
    "terminal.ansiGreen": "#98c379",
    "terminal.ansiMagenta": "#c678dd",
    "terminal.ansiRed": "#e06c75",
    "terminal.ansiWhite": "#abb2bf",
    "terminal.ansiYellow": "#e5c07b",
    "terminal.foreground": "#abb2bf",
    "terminal.tab.activeBorder": "#74ade8",
    "textBlockQuote.background": "#2B2B2B",
    "textBlockQuote.border": "#616161",
    "textCodeBlock.background": "#2B2B2B",
    "textLink.activeForeground": "#74ade8",
    "textLink.foreground": "#74ade8",
    "textPreformat.background": "#3C3C3C",
    "textPreformat.foreground": "#D0D0D0",
    "textSeparator.foreground": "#21262D",
    "titleBar.activeBackground": "#181818",
    "titleBar.activeForeground": "#CCCCCC",
    "titleBar.border": "#2B2B2B",
    "titleBar.inactiveBackground": "#1F1F1F",
    "titleBar.inactiveForeground": "#9D9D9D",
    "welcomePage.progress.foreground": "#74ade8",
    "welcomePage.tileBackground": "#2B2B2B",
    "widget.border": "#313131"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5d636f"
      }
    },
    {
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#878e98"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "meta.preprocessor keyword",
        "keyword.operator.word",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#b477cf"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": "meta.interface entity.name.function",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#878e98"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": "constant.language.boolean",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": [
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#dfc184"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#dfc184"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#73ade9"
      }
    },
    {
      "scope": "storage.type.function.arrow",
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": [
        "keyword.operator.type",
        "keyword.operator.optional"
      ],
      "settings": {
        "foreground": "#b1574b"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": [
        "entity.name.namespace",
        "entity.name.package",
        "entity.name.type.package"
      ],
      "settings": {
        "foreground": "#dce0e5"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": "variable.other.enummember",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#acb2be"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.terminator",
        "punctuation.other"
      ],
      "settings": {
        "foreground": "#b2b9c6"
      }
    },
    {
      "scope": [
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.typeparameters",
        "punctuation.definition.arguments",
        "punctuation.definition.array",
        "punctuation.section",
        "punctuation.definition.begin",
        "punctuation.definition.end",
        "punctuation.definition.bracket",
        "punctuation.definition.binding-pattern",
        "punctuation.definition.imports"
      ],
      "settings": {
        "foreground": "#b2b9c6"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#74ade8"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#74ade8"
      }
    },
    {
      "scope": "entity.name.label",
      "settings": {
        "foreground": "#74ade8"
      }
    },
    {
      "scope": [
        "punctuation.section.embedded",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#b1574b"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#bf956a"
      }
    },
    {
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#74ade8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#d07277"
      }
    },
    {
      "scope": "invalid.illegal",
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "scope": [
        "entity.name.command.shell",
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#a1c181"
      }
    },
    {
      "scope": "constant.other.option",
      "settings": {
        "foreground": "#6eb4bf"
      }
    },
    {
      "scope": "string.unquoted.argument",
      "settings": {
        "foreground": "#acb2be"
      }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly:go": "#dfc184",
    "string.format:go": "#bf956a",
    "variable.readonly:typescript": "#dfc184",
    "variable.readonly:typescriptreact": "#dfc184",
    "variable.readonly:javascript": "#dfc184",
    "variable.readonly:javascriptreact": "#dfc184",
    "namespace": "#dce0e5",
    "class": "#6eb4bf",
    "enum": "#6eb4bf",
    "interface": "#6eb4bf",
    "struct": "#6eb4bf",
    "typeParameter": "#6eb4bf",
    "type": "#6eb4bf",
    "parameter": "#d07277",
    "variable.constant": "#dfc184",
    "variable": "#acb2be",
    "property": "#d07277",
    "enumMember": "#73ade9",
    "decorator": "#74ade8",
    "function": "#73ade9",
    "method": "#73ade9",
    "macro": "#73ade9",
    "label": "#74ade8",
    "comment.documentation": "#878e98",
    "comment": "#5d636f",
    "string": "#a1c181",
    "keyword": "#b477cf",
    "number": "#bf956a",
    "regexp": "#a1c181",
    "operator": "#6eb4bf",
    "event": "#6eb4bf"
  }
}
